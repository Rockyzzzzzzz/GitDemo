<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Loan Department"  parallel="tests"  thread-count="2">
	<listeners>
		
		<listener class-name="TestNgTutorial.Listeners"/>
		
	</listeners>
	
	<parameter name="URR" value="LoanDepartment.com"/>
	
  <test name="Personal Loan" parallel="classes"  thread-count="2" >
	<parameter name="URL" value="PersonalLoan.com"/>
	
    <classes>
      <class name="TestNgTutorial.Day1">
		<methods>
			<include name="demo"/>
			
		</methods>
		
		</class>	
      <class name="TestNgTutorial.Day2"/>
       <class name="TestNgTutorial.Day4"/>
    </classes>
  </test> 
  
  <test name="Car Loan">
	<parameter name="URL" value="CarLoan.com"/>
	<parameter name="APIKey/username" value="123456"/>
    <classes>
      <class name="TestNgTutorial.Day3">
		<methods>
			                                            
			<exclude name="api.*"/>                  
			
		</methods>
		
		</class>
    </classes>
  </test> 
</suite> 
